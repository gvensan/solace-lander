# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite database. The baseline data/lander.db is intentionally committed as the
# build-time seed (it's the only DB file bundled to production). Its transient WAL/SHM
# sidecar files must NOT be committed — they aren't bundled, so any rows parked in the
# WAL get silently dropped in prod. Checkpoint lander.db before committing it.
# *.db
*.db-journal
*.db-wal
*.db-shm
